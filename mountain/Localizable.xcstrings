        "en" : { "stringUnit" : { "state" : "translated", "value" : "About" } }
      }
    },
    "Add favorite" : {
      "comment" : "Accessibility label for the favorite star button",
      "localizations" : {
        "de" : { "stringUnit" : { "state" : "translated", "value" : "Favorit hinzufügen" } },
        "en" : { "stringUnit" : { "state" : "translated", "value" : "Add favorite" } }
      }
    },
    "Band" : {
      "comment" : "Fallback navigation title on the band detail screen",
      "localizations" : {
        "de" : { "stringUnit" : { "state" : "translated", "value" : "Band" } },
        "en" : { "stringUnit" : { "state" : "translated", "value" : "Band" } }
      }
    },
    "Band not found" : {
      "localizations" : {
        "de" : { "stringUnit" : { "state" : "translated", "value" : "Band nicht gefunden" } },
        "en" : { "stringUnit" : { "state" : "translated", "value" : "Band not found" } }
      }
    },
    "Both apps and the API that serves the data are open source." : {
      "localizations" : {
        "de" : { "stringUnit" : { "state" : "translated", "value" : "Beide Apps und die API, die die Daten liefert, sind Open Source." } },
        "en" : { "stringUnit" : { "state" : "translated", "value" : "Both apps and the API that serves the data are open source." } }
      }
    },
    "Connect to the internet once to download the schedule." : {
      "localizations" : {
        "de" : { "stringUnit" : { "state" : "translated", "value" : "Verbinde dich einmal mit dem Internet, um das Programm zu laden." } },
        "en" : { "stringUnit" : { "state" : "translated", "value" : "Connect to the internet once to download the schedule." } }
      }
    },
    "Favorites only" : {
      "localizations" : {
        "de" : { "stringUnit" : { "state" : "translated", "value" : "Nur Favoriten" } },
        "en" : { "stringUnit" : { "state" : "translated", "value" : "Favorites only" } }
      }
    },
    "Find me online" : {
      "localizations" : {
        "de" : { "stringUnit" : { "state" : "translated", "value" : "Online findest du mich" } },
        "en" : { "stringUnit" : { "state" : "translated", "value" : "Find me online" } }
      }
    },
    "Hey, I'm Thore! A podcaster and software developer from the Ruhr area. I've loved Dong Open Air for many years, and this app is basically my little love letter to the festival." : {
      "localizations" : {
        "de" : { "stringUnit" : { "state" : "translated", "value" : "Moin, ich bin Thore! Podcaster und Softwareentwickler aus dem Ruhrgebiet. Das Dong Open Air liebe ich schon seit vielen Jahren, und diese App ist quasi mein kleiner Liebesbrief an das Festival." } },
        "en" : { "stringUnit" : { "state" : "translated", "value" : "Hey, I'm Thore! A podcaster and software developer from the Ruhr area. I've loved Dong Open Air for many years, and this app is basically my little love letter to the festival." } }
      }
    },
    "I'm also a huge Magic: The Gathering fan. If we bump into each other at Dong, let's play a round. And if you enjoy the app, I'd be happy if you grabbed me a beer." : {
      "localizations" : {
        "de" : { "stringUnit" : { "state" : "translated", "value" : "Außerdem bin ich ein riesiger Magic: The Gathering Fan. Wenn wir uns auf dem Dong über den Weg laufen, lass uns gerne eine Runde spielen. Und wenn dir die App gefällt, freue ich mich riesig über ein Bier." } },
        "en" : { "stringUnit" : { "state" : "translated", "value" : "I'm also a huge Magic: The Gathering fan. If we bump into each other at Dong, let's play a round. And if you enjoy the app, I'd be happy if you grabbed me a beer." } }
      }
    },
    "Line-up" : {
      "comment" : "Title of the full schedule tab",
      "localizations" : {
        "de" : { "stringUnit" : { "state" : "translated", "value" : "Programm" } },
        "en" : { "stringUnit" : { "state" : "translated", "value" : "Line-up" } }
      }
    },
    "Listen & Follow" : {
      "localizations" : {
        "de" : { "stringUnit" : { "state" : "translated", "value" : "Anhören & Folgen" } },
        "en" : { "stringUnit" : { "state" : "translated", "value" : "Listen & Follow" } }
      }
    },
